# Supabase PostgreSQL Database Connection String
DATABASE_URL="postgresql://your_username:your_password@your_host:your_port/your_database"

# Port on which the API Server runs (referenced by the frontend Vite proxy)
PORT=3001

# Comma-separated list of Clerk User IDs that are allowed access to the admin panel (e.g. user_2eA...,user_2eB...)
ADMIN_USER_IDS="user_xxx,user_yyy"

# Clerk API Keys (Required for backend auth)
# Get these from your Clerk dashboard (https://dashboard.clerk.com)
CLERK_PUBLISHABLE_KEY="pk_test_your_publishable_key"
CLERK_SECRET_KEY="sk_test_your_secret_key"
